#!/usr/bin/env zsh

setopt extended_glob

ACTION="$1"
ITEM="$2"
shift # Shift out the action, so "$@" contains the target files if any

# Semantic UI Constants
readonly C_RST='\033[0m'
readonly C_RED='\033[1;31m'
readonly C_GRN='\033[1;32m'
readonly C_YLW='\033[1;33m'
readonly C_CYN='\033[1;36m'
readonly C_MAG='\033[1;35m'

print_title()  { printf "%b=== %s ===%b\n" "$C_CYN" "$1" "$C_RST"; }
print_warn()   { printf "%b=== %s ===%b\n\n" "$C_RED" "$1" "$C_RST"; }
print_label()  { printf "%b%s%b" "$C_GRN" "$1" "$C_RST"; }
print_hl()     { printf "%b%s%b" "$C_YLW" "$1" "$C_RST"; }
print_clip()   { printf "[%b%s: %d%b] " "$C_MAG" "$1" "$2" "$C_RST"; }

# =========================================================
# Core Command Implementations
# =========================================================

ipre_action_run() {
    cd "$(<"$IPRE_CWD_FILE")" || exit 0
    local run_cmd="$IPRE_FD_CMD_STR"
    local targets="$(<"$IPRE_TARGETS_FILE")"
    if [[ "$(<"$IPRE_HIDDEN_FILE")" == "true" ]]; then
        run_cmd="$run_cmd --hidden"
    fi
    local depth="$(<"$IPRE_RAM_DEPTH_FILE" 2>/dev/null)"
    if [[ -n "$depth" && "$depth" -gt 0 ]]; then
        run_cmd="$run_cmd --maxdepth $depth"
    fi
    local sort_mode="$(<"$IPRE_SORT_FILE" 2>/dev/null)"
    local eza_opts="-1d --color=never --no-quotes"
    case "$sort_mode" in
        time) eza_opts+=" --sort=modified --reverse" ;; # Newest first
        size) eza_opts+=" --sort=size --reverse" ;;     # Largest first
        ext)  eza_opts+=" --sort=extension" ;;          # By extension
        *)    eza_opts+=" --sort=name" ;;               # Case-insensitive natural sort
    esac
    # call different process among 'all', 'file' and 'directory'
    local state="$(<"$IPRE_STATE_FILE")"
    run_fd_eza_stream() {
        local type_flag="$1"
        local append_slash="$2"
        local full_cmd="$run_cmd --type $type_flag $targets -X eza $=eza_opts"
        # NOTE: "sed 's/ -> .*//'" to remove soft link target
        if [[ "$append_slash" == "true" ]]; then
            eval "$full_cmd" 2>/dev/null | sed 's/ -> .*//' | sed 's|^\./||; s|/\?$|/|'
        else
            eval "$full_cmd" 2>/dev/null | sed 's/ -> .*//' | sed 's|^\./||'
        fi
    }
    if [[ "$state" == "directory" ]]; then
        run_fd_eza_stream "d" "true" || true
    elif [[ "$state" == "file" ]]; then
        run_fd_eza_stream "f" "false" || true
    else
        run_fd_eza_stream "d" "true" || true
        run_fd_eza_stream "f" "false" || true
    fi
}

